# AstroHome environment — copy to .env and fill in.
# The installer (scripts/install/seed-env.sh) uses this file as the prompt
# source; keys with a value here are defaults, keys with an empty value
# are prompted for, keys marked #REQUIRED must be set before services
# will start, keys marked #GEN are auto-generated if left empty.

NODE_ENV=production

# ---- LLM providers (at least one key is required) ----
#REQUIRED-ONE-OF
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=
# MiniMax M2 — Anthropic-compatible. https://www.minimax.io
MINIMAX_API_KEY=
# Moonshot AI (Kimi K2.6) — OpenAI-compatible. https://platform.moonshot.ai
# Strong on agentic tool-use; ~5-10× cheaper than Sonnet on output.
KIMI_API_KEY=
# DeepSeek V4 — OpenAI-compatible. https://platform.deepseek.com
# Cheapest option; v4-flash serves fast/standard, v4-pro (thinking) serves
# the powerful tier. Structured tasks (planning, verification) work on
# DeepSeek via the router's prompt-JSON path — no json_schema needed.
DEEPSEEK_API_KEY=

# ---- LLM routing ----
# Which provider fills all three tiers at boot. Normally auto-picked by key
# presence (anthropic > openai > gemini > minimax > kimi > deepseek >
# ollama); set this to hoist the provider whose credit you actually run on
# (e.g. "deepseek"). Admin per-tier overrides still take precedence. Any
# registered provider can also be re-routed per-tier at runtime via the
# admin UI or PUT /api/v1/admin/llm/routing.
LLM_DEFAULT_PROVIDER=
# Override only if you need a regional Kimi endpoint (default: api.moonshot.ai/v1).
KIMI_BASE_URL=
# Override only if needed (default: api.deepseek.com/v1).
DEEPSEEK_BASE_URL=
# DeepSeek's prod endpoint regressed `response_format: json_schema` (returns
# 400 "This response_format type is unavailable now"). Default is off (uses
# json_object mode). Set to "1" only when DEEPSEEK_BASE_URL points at a
# mirror that still honors json_schema (Together AI, Fireworks).
DEEPSEEK_SUPPORTS_STRUCTURED_OUTPUTS=

# ---- Core kernel secrets ----
#REQUIRED
ASTROHOME_ADMIN_PASSWORD=
#GEN
ASTROHOME_JWT_SECRET=
#GEN
ASTROHOME_SERVICE_SECRET=

# ---- Ports ----
# The two service ports. The setup wizard asks for these and DERIVES every
# address below from them (KERNEL_URL, WHATSAPP_BOT_URL, WEB_BASE_URL,
# KERNEL_PUBLIC_URL) so they can never drift. If you edit a port by hand,
# update the matching URL(s) too.
# Kernel gateway — the web UI + API. Everything talks to Astro here.
ASTROHOME_GATEWAY_PORT=8420
# WhatsApp bot service (only used if you run the WhatsApp bot).
WHATSAPP_BOT_PORT=8430
# Externally reachable base URL of the kernel — mints signed file URLs.
# Local install: http://localhost:<gateway port>. A tunnel overwrites this
# with the public https URL. Leave blank to let the kernel derive it.
KERNEL_PUBLIC_URL=

# ---- WhatsApp bot ----
# E.164 format, e.g. +14155550123. Leave empty to skip WhatsApp service.
BOT_PHONE=
# Derived from the ports above (kernel → bot, bot → kernel).
WHATSAPP_BOT_URL=http://127.0.0.1:8430
KERNEL_URL=http://127.0.0.1:8420
# Public URL of the web client (used in WhatsApp replies with deep links).
# The installer rewrites this to https://astro.<your-domain> after the tunnel is up.
WEB_BASE_URL=http://localhost:8420

# ---- Optional integrations ----
HA_URL=
HA_ACCESS_TOKEN=
BRAVE_SEARCH_API_KEY=

# ---- Brain routing & escalation ----
# Difficulty-based escalation: hard interactive turns run the POWERFUL tier
# with reasoning enabled (Anthropic thinking budgets / OpenAI reasoning
# effort / Gemini thinkingConfig / DeepSeek v4-pro) instead of being pinned
# to standard. A zero-cost heuristic fast-paths obvious cases. "0" disables.
CHAT_ESCALATION=1
# The fast-tier one-word classifier behind escalation's ambiguous middle.
# Raced against memory search (no added latency), fails open to standard.
# "0" leaves heuristic routing only — no extra LLM call, ever.
CHAT_ESCALATION_CLASSIFIER=1
# Tier for background/self-prompt agentic turns (research, plans,
# continuations). They are latency-insensitive and do the household's
# hardest work — "powerful" is the default and the recommendation.
BACKGROUND_BRAIN_TIER=powerful
# Tier for the voice brain (the ask_astro delegation behind Gemini Live).
# Voice is latency-sensitive; "fast" for snappy, "standard" for smarter.
VOICE_BRAIN_TIER=standard

# ---- Agency & self-improvement ----
# Verify a plan achieved its GOAL before reporting success; a confident
# "not achieved" routes back into the reviser to close the gap. "0" disables.
PLAN_VERIFY_ENABLED=1
# Advance open goals with linked plans every 6h without being nudged.
PROJECT_ADVANCE_ENABLED=1
# Nightly prune of stale synthesized tools/skills + proposals to crystallize
# recurring manual work into standing capabilities.
SELF_CURATION_ENABLED=1
# Astro-authored capabilities: sandbox-backed tools (author_capability,
# member+) and runtime skills (author_skill, admin-only). Both confirmation-
# gated and audited; "0" is the operator kill-switch.
SYNTH_TOOLS_ENABLED=1
SYNTH_SKILLS_ENABLED=1

# ---- Retrieval tuning ----
EMBEDDING_PROVIDER=auto
EMBEDDING_DIMENSIONS=512
RERANKER_ENABLED=0
# Keep cloud embeddings OFF the synchronous memory-search path — queries
# embed locally while the write/index path keeps cloud v2 vectors.
# Recall-gated (tests/integration/memory-recall.eval.test.ts); measured
# search p50 110ms -> ~2ms with cloud RTT out of the hot path.
EMBED_ASYNC_CLOUD=1
# Min-max normalize fused RRF relevance before composite scoring so results
# rank by relevance to the query, not by stored salience (~3x MRR on the
# recall gate). "0" restores legacy scoring.
MEMORY_RELEVANCE_NORMALIZE=1
# Per-stage latency spans (perf_spans table) for the chat/search hot path.
# Observability only — leave off unless you're profiling.
PERF_SPANS_ENABLED=0

# ---- MemPalace (optional, Python-backed) ----
MEMPALACE_ENABLED=0

# ---- Logging ----
LOG_LEVEL=info
LOG_PRETTY=0

# ---- Astro's own email identity (Resend, optional) ----
# Lets send_email deliver as Astro itself for users who haven't connected
# Gmail via OAuth (reminders, relays, proactive alerts). Verify a domain in
# Resend (SPF/DKIM DNS records) and use an address on it as the From.
RESEND_API_KEY=
ASTRO_EMAIL_FROM=Astro <astro@yourhousehold.com>

# ---- Mobile push (Firebase Cloud Messaging) ----
# FCM delivers push to Android directly and to iOS by proxying APNs (upload
# your APNs .p8 in the Firebase console → Cloud Messaging → Apple config).
# Drop the Firebase service-account JSON at config/secrets/fcm-service-account.json
# (gitignored) and the kernel picks it up automatically. Set this only to
# override that location — e.g. a mounted secret or an absolute path:
FCM_SERVICE_ACCOUNT_PATH=
